<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">

<node name="/com/telecom/smpp/client">

  <interface name="com.telecom.smpp.IClientHandler">

    <!-- Returns current session state. Callable by SMPPServer or operator tooling. -->
    <method name="GetSessionInfo">
      <arg name="session_id" type="s" direction="out"/>
      <arg name="client_ip"  type="s" direction="out"/>
      <arg name="system_id"  type="s" direction="out"/>
      <arg name="state"      type="s" direction="out"/>
      <arg name="bind_time"  type="t" direction="out"/>
    </method>

    <!-- Terminates the session cleanly. -->
    <method name="Disconnect">
      <arg name="reason" type="s" direction="in"/>
    </method>

    <!-- Deliver an MO message to a BOUND_RX or BOUND_TRX session.
         Returns the sequence number used in the deliver_sm PDU. -->
    <method name="DeliverSm">
      <arg name="src_addr"      type="s" direction="in"/>
      <arg name="dst_addr"      type="s" direction="in"/>
      <arg name="short_message" type="s" direction="in"/>
      <arg name="sequence_num"  type="u" direction="out"/>
    </method>

    <!-- Emitted on both clean shutdown and error termination before process exits. -->
    <signal name="SessionExited">
      <arg name="session_id" type="s"/>
      <arg name="reason"     type="s"/>
    </signal>

  </interface>

</node>
